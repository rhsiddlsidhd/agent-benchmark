# frontend/api/** (Vercel 서버리스 함수) 전용 — 서버 런타임에서만 읽힘
# 주의: VITE_ 접두사를 절대 붙이지 않는다 — 붙이면 클라이언트 번들에 그대로 노출됨
# frontend/src/**(클라이언트)는 이 값들에 직접 접근하지 않는다 — 전부 same-origin /api/* 경유

# 네이버 데이터랩 검색어트렌드 API (/api/naver-trend)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Supabase — posts 조회 (/api/posts, /api/summary 공유 service). RLS 우회 쓰기 권한 필요 — anon key 아님
# 사전에 posts 테이블 생성 필요(backend 크롤러와 동일 스키마): idxno(bigint, PK) / title(text)
#   / author(text, nullable) / posted_at(date) / views(int) / created_at(timestamptz, default now())
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI 요약 (/api/summary)
OPENAI_API_KEY=
OPENAI_MODEL=
